# Google Gemini API
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model — flash is free-tier, swap to gemini-3.5-pro for higher accuracy
GEMINI_MODEL=gemini-3.5-flash

# Database — SQLite for local dev (zero config)
DATABASE_URL=sqlite+aiosqlite:///./meetings.db

# For PostgreSQL, use:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meeting_intelligence

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
